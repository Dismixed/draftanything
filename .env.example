NEXT_PUBLIC_GA_ID=G-FWDTQFVL61
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Use the service_role / sb_secret key from Supabase dashboard — NOT the publishable key.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
ADMIN_EMAILS=you@example.com
# Set to true in local dev to require Supabase sign-in (matches production).
# ADMIN_REQUIRE_AUTH=true
GUEST_TOKEN_PEPPER=replace-with-at-least-32-characters
APP_URL=http://localhost:3000
CRON_SECRET=replace-with-random-secret-for-vercel-cron
# Remote Supabase only (no Docker): link once with `supabase link`, then `pnpm db:push`.
# .env.local should point at your cloud project URL + service role key — not localhost:54321.
GEMINI_API_KEY=gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite
# Optional — Imagen model for Hot Takes icon generation in admin.
GEMINI_IMAGE_MODEL=imagen-3.0-generate-002
# Optional — unlocks higher rate limits and sessions on The Trivia API.
TRIVIA_API_KEY=
# FreezeFrames admin — movie/TV stills via TMDB (free at https://www.themoviedb.org/settings/api).
TMDB_API_KEY=